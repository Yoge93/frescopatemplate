{
  "definitions": [
    {
      "title": "Find a Doctor",
      "id": "find-a-doctor",
      "plugins": {
        "xwalk": {
          "page": {
            "resourceType": "core/franklin/components/block/v1/block",
            "template": {
              "name": "Find a Doctor",
              "model": "find-a-doctor",
              "key-value": true
            }
          }
        }
      }
    }
  ],
  "models": [
    {
      "id": "find-a-doctor",
      "fields": [
        {
          "component": "text",
          "valueType": "string",
          "name": "title",
          "label": "Title",
          "value": "Find a Doctor"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "subtitle",
          "label": "Subtitle",
          "value": "Search for healthcare providers in your area"
        },
        {
          "component": "select",
          "name": "layout",
          "label": "Layout Style",
          "valueType": "string",
          "value": "default",
          "options": [
            {
              "name": "Default",
              "value": "default"
            },
            {
              "name": "Grid",
              "value": "grid"
            },
            {
              "name": "List",
              "value": "list"
            },
            {
              "name": "Card (Compact)",
              "value": "compact"
            },
            {
              "name": "Masonry",
              "value": "masonry"
            },
            {
              "name": "Expanded",
              "value": "expanded"
            }
          ]
        },
        {
          "component": "select",
          "name": "dataSourceType",
          "label": "Data Source Type",
          "valueType": "string",
          "value": "content-fragments",
          "options": [
            {
              "name": "Content Fragments",
              "value": "content-fragments"
            },
            {
              "name": "External API",
              "value": "api"
            }
          ]
        },
        {
          "component": "aem-content",
          "name": "contentFragmentFolder",
          "label": "Content Fragment Folder",
          "description": "Select folder containing multiple doctor Content Fragments",
          "valueType": "string",
          "validation": {
            "rootPath": "/content/dam"
          },
          "condition": {
            "==": [
              {
                "var": "dataSourceType"
              },
              "content-fragments"
            ]
          }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "apiUrl",
          "label": "API URL",
          "description": "External API endpoint for doctor data",
          "condition": {
            "==": [
              {
                "var": "dataSourceType"
              },
              "api"
            ]
          }
        },
        {
          "component": "boolean",
          "name": "enableLocationSearch",
          "label": "Enable Location Search",
          "value": "true",
          "valueType": "boolean"
        },
        {
          "component": "boolean",
          "name": "enableSpecialtyFilter",
          "label": "Enable Specialty / Tags Filter",
          "value": "true",
          "valueType": "boolean"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "specialtyLabel",
          "label": "Specialty Field Label",
          "value": "Specialty",
          "description": "Label shown above the specialty/tags dropdown",
          "condition": {
            "==": [
              {
                "var": "enableSpecialtyFilter"
              },
              true
            ]
          }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "specialtyPlaceholder",
          "label": "Specialty Dropdown Placeholder",
          "value": "All Specialties",
          "description": "Default placeholder option in the specialty dropdown",
          "condition": {
            "==": [
              {
                "var": "enableSpecialtyFilter"
              },
              true
            ]
          }
        },
        {
          "component": "boolean",
          "name": "enableProviderNameSearch",
          "label": "Enable Provider Name Search",
          "value": "true",
          "valueType": "boolean"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "providerNameLabel",
          "label": "Provider Name Field Label",
          "value": "Search by Provider Name",
          "description": "Label shown above the provider name search input",
          "condition": {
            "==": [
              {
                "var": "enableProviderNameSearch"
              },
              true
            ]
          }
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "providerNamePlaceholder",
          "label": "Provider Name Input Placeholder",
          "value": "Enter doctor's name...",
          "description": "Placeholder text inside the provider name input",
          "condition": {
            "==": [
              {
                "var": "enableProviderNameSearch"
              },
              true
            ]
          }
        },
        {
          "component": "boolean",
          "name": "enableSubmitAction",
          "label": "Enable Submit Action",
          "value": "true",
          "valueType": "boolean"
        },
        {
          "component": "text",
          "valueType": "string",
          "name": "submitUrl",
          "label": "Submit URL",
          "description": "URL to redirect to when Book Appointment is clicked (if Submit Action is enabled)",
          "condition": {
            "==": [
              {
                "var": "enableSubmitAction"
              },
              true
            ]
          }
        },
        {
          "component": "text",
          "name": "custom-class",
          "label": "Custom class",
          "value": "",
          "valueType": "string",
          "description": "Space-separated class names to add to the block"
        }
      ]
    }
  ],
  "filters": []
}
